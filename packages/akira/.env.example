# AKIRA - Motor de Extracción
# Ubicación: ~/proyectos/news/packages/akira/

# Base de datos SQLite (unificada)
AKIRA_DB=/Users/omatic/proyectos/news/packages/akira/data/akira.db

# Puerto del servidor
AKIRA_PORT=5000

# API Key para endpoints de ingest (si se usa API layer)
API_KEY=change-this-in-production

# MiniMax API (para sintesis y bias detection)
# Modelo: MiniMax-M2.7 | Endpoint: api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# Cloudflare (para futuro despliegue a Workers)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Rate limiting
RATE_LIMIT_DELAY=1.5
