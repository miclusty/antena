# AKIRA - Motor de Extracción
# Ubicación: ~/proyectos/news/packages/akira/

# Base de datos SQLite (unificada)
AKIRA_DB=/Users/omatic/proyectos/news/packages/akira/data/akira.db

# Puerto del servidor
AKIRA_PORT=5000

# API Key para endpoints de ingest (si se usa API layer)
API_KEY=change-this-in-production

# MiniMax API (para sintesis y bias detection)
# Modelo: MiniMax-M2.7 | Endpoint: api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# Cloudflare (para futuro despliegue a Workers)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# AKIRA → D1 sync (core/d1_sync.py + scripts/sync_to_d1_cron.py).
# These three are REQUIRED for the AKIRA→D1 mirror to run. If any
# is blank, sync calls log a warning and become no-ops.
# - Create the API token in Cloudflare dashboard → My Profile →
#   API Tokens → Create Token → template "Edit Cloudflare Workers"
#   (or a custom token with Account → D1 → Edit permission).
# - ACCOUNT_ID is in the Cloudflare dashboard URL or via
#   `wrangler whoami` from packages/api/.
# - DATABASE_ID is the D1 database ID — get it with
#   `wrangler d1 list` from packages/api/.
AKIRA_CLOUDFLARE_ACCOUNT_ID=
AKIRA_CLOUDFLARE_API_TOKEN=
AKIRA_D1_DATABASE_ID=

# Rate limiting
RATE_LIMIT_DELAY=1.5
