---
import '../lib/design-tokens.css';
import '../styles/animations.css';
import SeoHead from '../components/SeoHead.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props as Props;
const SITE = 'https://www.antena.com.ar';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <slot name="head">
      <SeoHead
        title={title ?? 'Sintonizá tu realidad'}
        description={description ?? 'Antena — Noticias sintetizadas de múltiples fuentes de cada localidad argentina. Mobile-first, sin tracking, 100% en español.'}
        canonical={canonical ?? SITE}
      />
    </slot>

    <!-- RSS / Atom discovery -->
    <link rel="alternate" type="application/rss+xml" title="Antena — Feed RSS" href="/rss.xml" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

    <!-- Structured data: WebSite (gives Google a sitelinks search box) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': 'https://www.antena.com.ar/#website',
      'name': 'Antena',
      'alternateName': 'Antena — Noticias HiperLocales',
      'url': 'https://www.antena.com.ar',
      'description': 'Síntesis de noticias de múltiples fuentes de cada localidad argentina',
      'inLanguage': 'es-AR',
      'publisher': { '@id': 'https://www.antena.com.ar/#organization' },
      'potentialAction': {
        '@type': 'SearchAction',
        'target': {
          '@type': 'EntryPoint',
          'urlTemplate': 'https://www.antena.com.ar/buscar?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    })} />

    <!-- Structured data: Organization (Knowledge Graph signal) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'NewsMediaOrganization',
      '@id': 'https://www.antena.com.ar/#organization',
      'name': 'Antena',
      'url': 'https://www.antena.com.ar',
      'logo': {
        '@type': 'ImageObject',
        'url': 'https://www.antena.com.ar/icons/icon.svg',
        'width': 512,
        'height': 512,
      },
      'description': 'Agregador de noticias argentino mobile-first. Mobile-first, sin tracking, 100% en español.',
      'foundingDate': '2026',
      'areaServed': {
        '@type': 'Country',
        'name': 'Argentina',
      },
      'inLanguage': 'es-AR',
      'sameAs': [
        'https://twitter.com/antena_ar',
      ],
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Apple Web App -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Antena" />
    <link rel="apple-touch-icon" href="/icons/icon.svg" />

    <!-- Preconnect to API + image CDN to remove
         ~200ms of DNS/TCP/TLS overhead on first hit. -->
    <link rel="preconnect" href="https://akira-api.miclusty.workers.dev" />
    <link rel="dns-prefetch" href="https://antena-images.r2.dev" />

    <!-- Material Symbols (icons). Self-hosted via
         @fontsource would be faster, but the Google CDN
         is acceptable with display=swap. Kept only as the
         icon font — text uses system fonts. -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght@20,300;20,400;24,300;24,400&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght@20,300;20,400;24,300;24,400&display=swap" rel="stylesheet" />

    <style>
      /* ─── Reset & Base ─── */
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: var(--bg-base);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: var(--text-base);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -webkit-tap-highlight-color: transparent;
        min-height: 100vh;
        min-height: 100dvh;
      }

      /* ─── Material Symbols ─── */
      .material-symbols-rounded {
        font-family: 'Material Symbols Rounded';
        font-variation-settings:
          'FILL' 0,
          'wght' 300,
          'GRAD' 0,
          'opsz' 20;
        font-size: 20px;
        line-height: 1;
        vertical-align: middle;
        user-select: none;
      }
      .material-symbols-rounded.filled {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 20;
      }
      .material-symbols-rounded.filled-lg {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        font-size: 24px;
      }

      /* ─── Scrollbar ─── */
      ::-webkit-scrollbar { width: 4px; height: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background: var(--border-strong, #2A2E3C);
        border-radius: 2px;
      }

      /* ─── Utilities ─── */
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .pb-safe { padding-bottom: env(safe-area-inset-bottom, 0.5rem); }
      .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .sr-only {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
      }

      /* ─── Focus visible ─── */
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }

      /* ─── Responsive layout padding for bottom nav ─── */
      #main-content {
        padding-bottom: calc(var(--bottom-nav-height) + env(safe-area-inset-bottom, 0px));
      }
      @media (min-width: 1024px) {
        #main-content {
          padding-bottom: 0;
        }
      }
    </style>

    <!-- Theme init: prevent FOUC -->
    <script>
      const saved = localStorage.getItem('antena-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      // Default to dark regardless of system preference, unless user explicitly chose light
      if (saved === 'light') {
        // keep light
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded">
      Saltar al contenido
    </a>
    <!--
      <main> sits directly under <body> (NOT inside the Solid
      <astro-island>) so axe-core recognizes it as a document
      landmark. The Solid app's own <main> would otherwise be
      nested inside the custom <astro-island> element, which
      axe excludes from landmark counting.
    -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </body>
</html>