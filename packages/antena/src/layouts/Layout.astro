---
import '../lib/design-tokens.css';
import '../styles/animations.css';
import SeoHead from '../components/SeoHead.astro';
import iconsSprite from '../icons.svg?raw';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props as Props;
const SITE = 'https://www.antena.com.ar';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <slot name="head">
      <SeoHead
        title={title ?? 'Sintonizá tu realidad'}
        description={description ?? 'Antena — Noticias sintetizadas de múltiples fuentes de cada localidad argentina. Mobile-first, sin tracking, 100% en español.'}
        canonical={canonical ?? SITE}
      />
    </slot>

    <!-- RSS / Atom discovery -->
    <link rel="alternate" type="application/rss+xml" title="Antena — Feed RSS" href="/rss.xml" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <link rel="sitemap" type="application/xml" title="Sitemap Index (per-province)" href="/sitemap-index.xml" />

    <!-- Structured data: WebSite (gives Google a sitelinks search box) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': 'https://www.antena.com.ar/#website',
      'name': 'Antena',
      'alternateName': 'Antena — Noticias HiperLocales',
      'url': 'https://www.antena.com.ar',
      'description': 'Síntesis de noticias de múltiples fuentes de cada localidad argentina',
      'inLanguage': 'es-AR',
      'publisher': { '@id': 'https://www.antena.com.ar/#organization' },
      'potentialAction': {
        '@type': 'SearchAction',
        'target': {
          '@type': 'EntryPoint',
          'urlTemplate': 'https://www.antena.com.ar/buscar?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    })} />

    <!-- Structured data: Organization (Knowledge Graph signal) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'NewsMediaOrganization',
      '@id': 'https://www.antena.com.ar/#organization',
      'name': 'Antena',
      'url': 'https://www.antena.com.ar',
      'logo': {
        '@type': 'ImageObject',
        'url': 'https://www.antena.com.ar/icons/icon.svg',
        'width': 512,
        'height': 512,
      },
      'description': 'Agregador de noticias argentino mobile-first. Mobile-first, sin tracking, 100% en español.',
      'foundingDate': '2026',
      'areaServed': {
        '@type': 'Country',
        'name': 'Argentina',
      },
      'inLanguage': 'es-AR',
      'sameAs': [
        'https://twitter.com/antena_ar',
      ],
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- VitePWA generates /manifest.webmanifest at build; we removed public/manifest.json in 2026-07-09 to fix the conflict -->

    <!-- Apple Web App -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Antena" />
    <!-- NOTE: 2026-07-09 — switch apple-touch-icon from SVG (ignored by Safari) to PNG once icon-180.png is generated via scripts/generate-icons.mjs -->

    <!-- Preconnect to API + image CDN to remove
         ~200ms of DNS/TCP/TLS overhead on first hit. -->
    <link rel="preconnect" href="https://akira-api.miclusty.workers.dev" />
    <link rel="dns-prefetch" href="https://antena-images.r2.dev" />

    <!-- Icons via SVG sprite (36 KB, replaces 1.9 MB Material Symbols font).
         Inlined via ?raw import to avoid an extra HTTP request. The sprite
         is hidden via style="display:none" and referenced via <use href="#icon-name" />
         from the MaterialIcon component. -->
    <Fragment set:html={iconsSprite} />

    <style>
      /* ─── Reset & Base ─── */
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: var(--bg-base);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: var(--text-base);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -webkit-tap-highlight-color: transparent;
        min-height: 100vh;
        min-height: 100dvh;
      }

      /* ─── Scrollbar ─── */
      ::-webkit-scrollbar { width: 4px; height: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background: var(--border-strong, #2A2E3C);
        border-radius: 2px;
      }

      /* ─── Utilities ─── */
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .pb-safe { padding-bottom: env(safe-area-inset-bottom, 0.5rem); }
      .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .sr-only {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
      }

      /* ─── Focus visible ─── */
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }

      /* ─── Responsive layout padding for bottom nav ─── */
      #main-content {
        padding-bottom: calc(var(--bottom-nav-height) + env(safe-area-inset-bottom, 0px));
      }
      @media (min-width: 1024px) {
        #main-content {
          padding-bottom: 0;
        }
      }

      /* ─── Article body (S3.3) ─── */
      .article-body p { margin: 0 0 1em; }
      .article-body h2 {
        font-size: 22px;
        font-weight: 700;
        line-height: 1.3;
        margin: 2em 0 0.75em;
        color: var(--text-primary);
        scroll-margin-top: calc(var(--header-height) + 12px);
      }
      .article-body h3 {
        font-size: 18px;
        font-weight: 600;
        line-height: 1.35;
        margin: 1.75em 0 0.6em;
        color: var(--text-primary);
        scroll-margin-top: calc(var(--header-height) + 12px);
      }
      .article-body blockquote {
        border-left: 3px solid var(--accent);
        padding: 0.25em 1em;
        margin: 1.25em 0;
        color: var(--text-secondary);
        font-style: italic;
      }
      .article-body ul, .article-body ol {
        margin: 0 0 1em;
        padding-left: 1.5em;
      }
      .article-body li { margin: 0.25em 0; }
      .article-body figure { margin: 1.5em 0; }
      .article-body figcaption {
        font-size: 14px;
        color: var(--text-tertiary);
        text-align: center;
        margin-top: 0.5em;
      }
      .article-body a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
      .article-body img { max-width: 100%; height: auto; border-radius: 8px; }
      .article-body table {
        width: 100%;
        border-collapse: collapse;
        margin: 1em 0;
        font-size: 15px;
      }
      .article-body th, .article-body td {
        border: 1px solid var(--border-base);
        padding: 0.5em 0.75em;
        text-align: left;
      }
      .article-body th { background: var(--bg-hover); font-weight: 600; }
      .article-body code {
        background: var(--bg-hover);
        padding: 0.1em 0.35em;
        border-radius: 4px;
        font-family: var(--font-mono);
        font-size: 0.9em;
      }
    </style>

    <!-- Theme init: prevent FOUC -->
    <script>
      const saved = localStorage.getItem('antena-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      // Default to dark regardless of system preference, unless user explicitly chose light
      if (saved === 'light') {
        // keep light
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded">
      Saltar al contenido
    </a>
    <!--
      <main> sits directly under <body> (NOT inside the Solid
      <astro-island>) so axe-core recognizes it as a document
      landmark. The Solid app's own <main> would otherwise be
      nested inside the custom <astro-island> element, which
      axe excludes from landmark counting.
    -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </body>
</html>