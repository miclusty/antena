---
// Legacy /noticia/<id> → /<year>/<month>/<day>/<slug> redirect.
//
// In production, the actual 301 is performed at the edge by
// Cloudflare Pages: `packages/antena/public/_redirects` (the
// first 2000 rules, populated by packages/api/src/lib/redirects-generator.ts
// at prebuild time) and the worker middleware (long tail, from
// .redirects-cache.json).
//
// This Astro page is the static fallback for builds that ran
// without D1 access (so the redirects file is empty) and for
// any future environment that doesn't honor the edge redirect.
// The page emits a meta-refresh + a visible link to the new URL.
//
// Phase 3 Task 34.

import Layout from '../../layouts/Layout.astro';
import SeoHead from '../../components/SeoHead.astro';

export const prerender = true;

interface SsrArticle {
  id: string;
  title: string;
  published_at: string | null;
  slug: string | null;
  slug_date: string | null;
}

export async function getStaticPaths() {
  const SITE = 'https://www.antena.com.ar';
  const slugify = (s: string) => s
    .toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 80);

  const fromEnv = import.meta.env.PUBLIC_API_BASE;
  const apiBase = (!fromEnv || fromEnv.includes('localhost'))
    ? 'https://akira-api.miclusty.workers.dev'
    : fromEnv;
  const paths: { params: { id: string }; props: { canonical: string | null } }[] = [];
  try {
    const res = await fetch(`${apiBase}/api/news/feed?limit=100&offset=0`, {
      headers: { 'User-Agent': 'AntenaSSRBatcher/1.0' },
    });
    if (res.ok) {
      const data = await res.json() as { news: SsrArticle[] };
      const newsArr = data.news ?? [];
      for (const a of newsArr) {
        let canonical: string | null = null;
        if (a.slug && a.slug_date) {
          const [y, m, d] = a.slug_date.split('-');
          canonical = `${SITE}/${y}/${m}/${d}/${a.slug}`;
        } else if (a.published_at && a.title) {
          const [y, m, d] = a.published_at.slice(0, 10).split('-');
          const sl = slugify(a.title);
          if (sl) canonical = `${SITE}/${y}/${m}/${d}/${sl}`;
        }
        paths.push({ params: { id: a.id }, props: { canonical } });
      }
    }
  } catch {}
  return paths;
}

const { canonical } = Astro.props as { canonical: string | null };
const SITE = 'https://www.antena.com.ar';
---
<Layout>
  <Fragment slot="head">
    <SeoHead
      title="Noticia movida — Antena"
      description="Esta nota se mudó a una nueva URL. Te redirigimos automáticamente."
      canonical={canonical ?? SITE}
      noindex={true}
    />
    {canonical && (
      <>
        <meta http-equiv="refresh" content={`0; url=${canonical}`} />
        <link rel="canonical" href={canonical} />
      </>
    )}
  </Fragment>
  <main id="main-content" class="min-h-[60vh] flex flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-2xl font-bold mb-3" style={{ color: 'var(--text-primary)' }}>
      Noticia movida
    </h1>
    {canonical ? (
      <p class="text-base" style={{ color: 'var(--text-secondary)' }}>
        Esta nota se encuentra ahora en{' '}
        <a href={canonical} style={{ color: 'var(--accent)' }} class="underline">{canonical}</a>.
      </p>
    ) : (
      <p class="text-base" style={{ color: 'var(--text-secondary)' }}>
        Si no sos redirigido automáticamente, <a href="/" style={{ color: 'var(--accent)' }} class="underline">volvé al feed</a>.
      </p>
    )}
  </main>
</Layout>
