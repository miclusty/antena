---
// Pre-renders every recent news card at build time so each
// /noticia/<id> URL has full meta tags, Open Graph, and
// JSON-LD NewsArticle schema for SEO and LLM crawlers.
//
// The actual interactive article view is rendered
// client-side by App.tsx (Solid island), so this page is
// the SEO/SSR surface. Anything not in getStaticPaths
// (e.g. brand-new cards) hits Astro's 404 and gets
// caught by the client-side router — acceptable for v1
// since cards are usually hours old by the time they're
// shared.

import Layout from '../../layouts/Layout.astro';

export const prerender = true;

interface SsrArticle {
  id: string;
  title: string;
  summary: string;
  body?: string | null;
  image_url: string | null;
  source_name: string | null;
  author?: string | null;
  category: string | null;
  location_name: string | null;
  published_at: string | null;
  source_url?: string | null;
}

export async function getStaticPaths() {
  // The API is reachable at build time via the worker
  // URL. If unavailable (offline build), return an empty
  // set so the build still succeeds.
  // Skip localhost during production builds — it always
  // fails to connect and produces empty paths.
  const fromEnv = import.meta.env.PUBLIC_API_BASE;
  const apiBase = (!fromEnv || fromEnv.includes('localhost'))
    ? 'https://akira-api.miclusty.workers.dev'
    : fromEnv;
  console.log(`[noticia] getStaticPaths: fetching from ${apiBase}`);
  try {
    const res = await fetch(`${apiBase}/api/news/feed?limit=100&offset=0`, {
      headers: { 'User-Agent': 'AntenaSSRBatcher/1.0' },
    });
    console.log(`[noticia] getStaticPaths: status ${res.status}`);
    if (!res.ok) return [];
    const data = await res.json() as { news: SsrArticle[] };
    console.log(`[noticia] getStaticPaths: ${data.news?.length ?? 0} articles`);
    return (data.news ?? []).map((n) => ({
      params: { id: n.id },
      props: { article: n },
    }));
  } catch (e) {
    console.log(`[noticia] getStaticPaths: error ${e}`);
    return [];
  }
}

const { article } = Astro.props as { article: SsrArticle };

const SITE = 'https://www.antena.com.ar';
const url = `${SITE}/noticia/${article.id}`;
const title = `${article.title} — Antena`;
const description = article.summary?.slice(0, 200) || 'Noticia en Antena';
const image = article.image_url || `${SITE}/icons/og-default.png`;
const author = article.author || article.source_name || 'Antena';
const publishedAt = article.published_at || new Date().toISOString();
const publisherName = 'Antena';
const publisherLogo = `${SITE}/icons/icon.svg`;
---
<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={article.title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Antena" />
    <meta property="article:published_time" content={publishedAt} />
    <meta property="article:author" content={author} />
    {article.category && <meta property="article:section" content={article.category} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={article.title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured data: NewsArticle for Google + LLMs -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      'headline': article.title,
      'description': description,
      'image': [image],
      'datePublished': publishedAt,
      'dateModified': publishedAt,
      'author': [{
        '@type': 'Person',
        'name': author,
        'url': `${SITE}/autor/${encodeURIComponent(author)}`,
      }],
      'publisher': {
        '@type': 'Organization',
        '@id': publisherLogo,
        'name': publisherName,
        'logo': {
          '@type': 'ImageObject',
          'url': publisherLogo,
        },
      },
      'mainEntityOfPage': {
        '@type': 'WebPage',
        '@id': url,
      },
      'articleSection': article.category || 'General',
      'inLanguage': 'es-AR',
      'isAccessibleForFree': true,
      // Speakable: tells Google Assistant / Alexa which
      // sections to read aloud for voice search results.
      'speakable': {
        '@type': 'SpeakableSpecification',
        'xpath': ['/html/head/title', '/html/body//article/h1', '/html/body//article/p[1]'],
      },
      ...(article.source_url ? { 'url': article.source_url } : {}),
    })} />

    <!-- BreadcrumbList: rich snippet breadcrumb in SERPs -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': SITE },
        ...(article.category ? [{ '@type': 'ListItem', 'position': 2, 'name': article.category, 'item': `${SITE}/?cat=${encodeURIComponent(article.category)}` }] : []),
        ...(article.location_name ? [{ '@type': 'ListItem', 'position': 3, 'name': article.location_name, 'item': `${SITE}/?loc=${encodeURIComponent(article.location_name)}` }] : []),
        { '@type': 'ListItem', 'position': 99, 'name': article.title, 'item': url },
      ].map((item, i, arr) => ({ ...item, position: arr.indexOf(item) + 1 })),
    })} />
  </Fragment>

  <main id="main-content" class="max-w-[680px] mx-auto px-4 py-8">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1.5 text-xs flex-wrap" style={{ color: 'var(--text-tertiary)' }}>
        <li><a href="/" class="hover:underline" style={{ color: 'var(--accent)' }}>Inicio</a></li>
        {article.category && (
          <>
            <li aria-hidden="true">›</li>
            <li><a href={`/?cat=${encodeURIComponent(article.category)}`} class="hover:underline" style={{ color: 'var(--accent)' }}>{article.category}</a></li>
          </>
        )}
        {article.location_name && (
          <>
            <li aria-hidden="true">›</li>
            <li><a href={`/?loc=${encodeURIComponent(article.location_name)}`} class="hover:underline" style={{ color: 'var(--accent)' }}>{article.location_name}</a></li>
          </>
        )}
        <li aria-hidden="true">›</li>
        <li class="truncate max-w-[200px]" style={{ color: 'var(--text-secondary)' }} aria-current="page">{article.title}</li>
      </ol>
    </nav>
    <article class="mt-6">
      <header>
        <p class="text-[10px] font-bold uppercase tracking-widest mb-2" style={{ color: 'var(--text-tertiary)' }}>
          {article.category || 'General'}
          {article.location_name && <> · {article.location_name}</>}
        </p>
        <h1 class="text-[28px] font-bold leading-tight" style={{ color: 'var(--text-primary)' }}>
          {article.title}
        </h1>
        <p class="mt-3 text-sm" style={{ color: 'var(--text-tertiary)' }}>
          Por <span style={{ color: 'var(--text-secondary)' }}>{author}</span>
          {' · '}
          <time datetime={publishedAt}>
            {new Date(publishedAt).toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </p>
      </header>

      {article.image_url && (
        <figure class="mt-6">
          <img
            src={`https://akira-api.miclusty.workers.dev/api/img?url=${encodeURIComponent(article.image_url)}&w=1200&q=75&fmt=webp&fit=cover`}
            srcset={`https://akira-api.miclusty.workers.dev/api/img?url=${encodeURIComponent(article.image_url)}&w=600&q=70&fmt=webp&fit=cover 600w, https://akira-api.miclusty.workers.dev/api/img?url=${encodeURIComponent(article.image_url)}&w=1200&q=75&fmt=webp&fit=cover 1200w, https://akira-api.miclusty.workers.dev/api/img?url=${encodeURIComponent(article.image_url)}&w=1800&q=78&fmt=webp&fit=cover 1800w`}
            sizes="(max-width: 768px) 100vw, 920px"
            alt={article.title}
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto rounded-xl"
          />
        </figure>
      )}

      <p class="mt-6 text-lg leading-relaxed" style={{ color: 'var(--text-primary)' }}>
        {article.summary}
      </p>

      {article.body && (
        <div class="mt-4 text-base leading-relaxed prose" style={{ color: 'var(--text-secondary)' }}>
          {article.body}
        </div>
      )}

      <p class="mt-8 text-sm">
        <a href={url} class="font-semibold" style={{ color: 'var(--accent)' }}>Leer en Antena →</a>
      </p>
    </article>
  </main>
</Layout>
