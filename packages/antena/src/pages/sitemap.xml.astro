---
// Pre-renders /sitemap-index.xml at build time with the
// 100 most recent article URLs + the static pages. Sitemaps
// are a primary SEO signal — every shareable URL should be
// in one of these files so crawlers (Google, Bing,
// DuckDuckGo, AI scrapers) can discover it.

import Layout from '../layouts/Layout.astro';

export const prerender = true;

interface SsrArticle {
  id: string;
  published_at: string | null;
  slug: string | null;
  slug_date: string | null;
  location_name: string | null;
  category: string | null;
}

const SITE = 'https://www.antena.com.ar';

async function fetchArticles(): Promise<SsrArticle[]> {
  const fromEnv = import.meta.env.PUBLIC_API_BASE;
  const apiBase = (!fromEnv || fromEnv.includes('localhost'))
    ? 'https://akira-api.miclusty.workers.dev'
    : fromEnv;
  try {
    const batchRes = await fetch(`${apiBase}/api/news/sitemap-batch?limit=500&offset=0`, {
      headers: { 'User-Agent': 'AntenaSSRBatcher/1.0' },
    });
    if (batchRes.ok) {
      const batchData = await batchRes.json() as { items: SsrArticle[] };
      if (batchData.items?.length) return batchData.items;
    }
    const res = await fetch(`${apiBase}/api/news/feed?limit=100&offset=0`, {
      headers: { 'User-Agent': 'AntenaSSRBatcher/1.0' },
    });
    if (!res.ok) return [];
    const data = await res.json() as { news: SsrArticle[] };
    return data.news ?? [];
  } catch {
    return [];
  }
}

const articles = await fetchArticles();
const now = new Date().toISOString();

const cities = new Set<string>();
const categories = new Set<string>();
for (const a of articles) {
  if (a.location_name) cities.add(a.location_name);
  if (a.category) categories.add(a.category);
}

const slugify = (s: string) => s
  .toLowerCase()
  .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-+|-+$/g, '');

const urls = [
  { loc: `${SITE}/`, lastmod: now, changefreq: 'hourly', priority: '1.0' },
  { loc: `${SITE}/buscar`, lastmod: now, changefreq: 'weekly', priority: '0.6' },
  { loc: `${SITE}/settings`, lastmod: now, changefreq: 'monthly', priority: '0.3' },
  ...Array.from(cities).slice(0, 20).map((c) => ({
    loc: `${SITE}/ciudad/${slugify(c)}`,
    lastmod: now,
    changefreq: 'hourly',
    priority: '0.8',
  })),
  ...Array.from(categories).slice(0, 15).map((c) => ({
    loc: `${SITE}/categoria/${slugify(c)}`,
    lastmod: now,
    changefreq: 'hourly',
    priority: '0.8',
  })),
  ...articles.map((a) => {
    const loc = a.slug && a.slug_date
      ? `${SITE}/${a.slug_date.split('-').join('/')}/${a.slug}`
      : `${SITE}/noticia/${a.id}`;
    return {
      loc,
      lastmod: a.published_at ?? now,
      changefreq: 'weekly',
      priority: '0.8',
    };
  }),
];
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{urls.map((u) => (
  <url>
    <loc>{u.loc}</loc>
    <lastmod>{u.lastmod}</lastmod>
    <changefreq>{u.changefreq}</changefreq>
    <priority>{u.priority}</priority>
  </url>
))}
</urlset>
