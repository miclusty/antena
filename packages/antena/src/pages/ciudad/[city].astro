---
// /ciudad/[city].astro — Topic hub per location.
// Lists all articles from a given city with a strong
// intro paragraph (locally-keyworded) + ItemList JSON-LD
// + WebPage + BreadcrumbList. The pre-rendered set of
// cities comes from the locations table joined to
// recent news; an empty city has no page.

import Layout from '../../layouts/Layout.astro';
export const prerender = true;

interface SsrArticle {
  id: string;
  title: string;
  summary: string;
  image_url: string | null;
  source_name: string | null;
  author: string | null;
  category: string | null;
  location_name: string | null;
  published_at: string | null;
}

const SITE = 'https://www.antena.com.ar';

export async function getStaticPaths() {
  const slugify = (s: string) => s
    .toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
  const fromEnv = import.meta.env.PUBLIC_API_BASE;
  const apiBase = (!fromEnv || fromEnv.includes('localhost'))
    ? 'https://akira-api.miclusty.workers.dev'
    : fromEnv;
  let paths: { params: { city: string }; props: { cityName: string; articles: SsrArticle[] } }[] = [];
  try {
    const res = await fetch(`${apiBase}/api/news/feed?limit=100&offset=0`, {
      headers: { 'User-Agent': 'AntenaSSRBatcher/1.0' },
    });
    if (res.ok) {
      const data = await res.json() as { news: SsrArticle[] };
      const byCity = new Map<string, SsrArticle[]>();
      for (const a of data.news ?? []) {
        const city = (a.location_name || '').trim();
        if (!city) continue;
        const arr = byCity.get(city) ?? [];
        arr.push(a);
        byCity.set(city, arr);
      }
      const sorted = Array.from(byCity.entries())
        .sort((a, b) => b[1].length - a[1].length)
        .slice(0, 20);
      paths = sorted.map(([name, articles]) => ({
        params: { city: slugify(name) },
        props: { cityName: name, articles },
      }));
    }
  } catch {}
  return paths;
}

const { city } = Astro.params;
const { cityName, articles } = Astro.props as { cityName: string; articles: SsrArticle[] };
if (!articles || articles.length === 0) {
  return Astro.redirect('/');
}
const canonical = `${SITE}/ciudad/${city}`;
---
<Layout
  title={`Noticias de ${cityName}`}
  description={`Todas las noticias de ${cityName} en Antena. Cobertura sintetizada de múltiples medios locales de ${cityName}, actualizada en tiempo real.`}
  canonical={canonical}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`Noticias de ${cityName} — Antena`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://www.antena.com.ar/og-default.png" />

    <!-- ItemList JSON-LD: this page IS a list of news items -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      'name': `Noticias de ${cityName}`,
      'description': `Cobertura de noticias de ${cityName} en Argentina`,
      'url': canonical,
      'itemListElement': articles.slice(0, 20).map((a, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'item': {
          '@type': 'NewsArticle',
          'headline': a.title,
          'url': `${SITE}/noticia/${a.id}`,
          'datePublished': a.published_at,
          'author': a.author ? { '@type': 'Person', 'name': a.author } : undefined,
        },
      })),
    })} />

    <!-- WebPage schema for this hub -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      'name': `Noticias de ${cityName}`,
      'description': `Cobertura de noticias de ${cityName} en Argentina`,
      'url': canonical,
      'inLanguage': 'es-AR',
      'isPartOf': { '@id': 'https://www.antena.com.ar/#website' },
      'about': { '@type': 'Place', 'name': cityName, 'address': { '@type': 'PostalAddress', 'addressCountry': 'AR' } },
    })} />
  </Fragment>

  <main id="main-content" class="max-w-[920px] mx-auto px-4 py-8">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1.5 text-xs" style={{ color: 'var(--text-tertiary)' }}>
        <li><a href="/" class="hover:underline" style={{ color: 'var(--accent)' }}>Inicio</a></li>
        <li aria-hidden="true">›</li>
        <li style={{ color: 'var(--text-secondary)' }} aria-current="page">Ciudades</li>
        <li aria-hidden="true">›</li>
        <li style={{ color: 'var(--text-secondary)' }} aria-current="page">{cityName}</li>
      </ol>
    </nav>
    <header class="mt-6">
      <p class="text-[10px] font-bold uppercase tracking-widest mb-2" style={{ color: 'var(--accent)' }}>
        Ciudad · Argentina
      </p>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight" style={{ color: 'var(--text-primary)' }}>
        Noticias de {cityName}
      </h1>
      <p class="mt-3 text-base" style={{ color: 'var(--text-secondary)' }}>
        Cobertura sintetizada de múltiples medios locales de {cityName}. {articles.length} {articles.length === 1 ? 'noticia' : 'noticias'} recientes.
      </p>
    </header>

    <h2 class="text-xs font-bold uppercase tracking-widest mt-8 mb-3" style={{ color: 'var(--text-tertiary)' }}>
      Últimas notas
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {articles.map((a) => (
        <a
          href={`/noticia/${a.id}`}
          class="block rounded-xl border p-4 transition-colors hover:bg-bg-hover"
          style={{ 'border-color': 'var(--border-base)' }}
        >
          {a.image_url && (
            <img
              src={`/api/img/?url=${encodeURIComponent(a.image_url)}&w=600&q=72&fmt=webp&fit=cover`}
              srcset={`/api/img/?url=${encodeURIComponent(a.image_url)}&w=300&q=68&fmt=webp&fit=cover 300w, /api/img/?url=${encodeURIComponent(a.image_url)}&w=600&q=72&fmt=webp&fit=cover 600w`}
              sizes="(max-width: 768px) 100vw, 460px"
              alt={a.title}
              width="600"
              height="300"
              loading="lazy"
              decoding="async"
              class="w-full h-40 object-cover rounded-lg mb-3"
            />
          )}
          <p class="text-[10px] font-bold uppercase tracking-wider mb-1" style={{ color: 'var(--text-tertiary)' }}>
            {a.category || 'General'}
            {a.author && <> · {a.author}</>}
          </p>
          <h3 class="text-base font-semibold leading-snug" style={{ color: 'var(--text-primary)' }}>
            {a.title}
          </h3>
          <p class="text-sm mt-2 line-clamp-2" style={{ color: 'var(--text-secondary)' }}>
            {a.summary.replace(/<[^>]+>/g, '').slice(0, 160)}
          </p>
          {a.published_at && (
            <time
              datetime={a.published_at}
              class="text-[10px] mt-2 block"
              style={{ color: 'var(--text-tertiary)' }}
            >
              {new Date(a.published_at).toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
        </a>
      ))}
    </div>
  </main>
</Layout>
