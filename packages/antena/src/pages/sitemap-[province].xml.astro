---
// Per-province sitemap at /sitemap-<province-slug>.xml
//
// Each page in this directory is one province's article sitemap.
// The list of provinces comes from a fixed set (24 Argentine
// provinces + CABA) so getStaticPaths generates one file at
// build time. The actual article list is fetched fresh at
// build time from the API.
//
// The slug is normalized (lowercase, accent-stripped, hyphens)
// so URLs are stable across casing/spelling variants.

import type { GetStaticPaths } from "astro";

export const prerender = true;

const SITE = "https://www.antena.com.ar";

// 24 provinces + CABA. We hardcode the list here because the
// number of provinces in Argentina is constitutionally fixed
// (Article 3 + 121 of the Constitution, plus CABA), so the
// list is stable and small. Updating the list requires a
// redeploy, which is fine since province-level sitemap
// structure changes slowly.
const PROVINCES = [
  "Buenos Aires",
  "Ciudad Autónoma de Buenos Aires",
  "Catamarca",
  "Chaco",
  "Chubut",
  "Córdoba",
  "Corrientes",
  "Entre Ríos",
  "Formosa",
  "Jujuy",
  "La Pampa",
  "La Rioja",
  "Mendoza",
  "Misiones",
  "Neuquén",
  "Río Negro",
  "Salta",
  "San Juan",
  "San Luis",
  "Santa Cruz",
  "Santa Fe",
  "Santiago del Estero",
  "Tierra del Fuego, Antártida e Islas del Atlántico Sur",
  "Tucumán",
];

const slugify = (s: string) => s
  .toLowerCase()
  .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/^-+|-+$/g, "");

export const getStaticPaths = (async () => {
  return PROVINCES.map((p) => ({
    params: { province: slugify(p) },
    props: { province: p },
  }));
}) satisfies GetStaticPaths;

interface Props {
  province: string;
}

const { province } = Astro.props as Props;

const fromEnv = import.meta.env.PUBLIC_API_BASE;
const apiBase = (!fromEnv || fromEnv.includes("localhost"))
  ? "https://akira-api.miclusty.workers.dev"
  : fromEnv;

interface SsrArticle {
  id: string;
  slug: string;
  slug_date: string;
  published_at: string | null;
}

let items: SsrArticle[] = [];
try {
  const res = await fetch(
    `${apiBase}/api/sitemap-province/${encodeURIComponent(province)}`,
    { headers: { "User-Agent": "AntenaSSRSitemapBuilder/1.0" } },
  );
  if (res.ok) {
    const text = await res.text();
    // The API returns an XML sitemap. We re-parse it to extract
    // <loc> URLs, then map each back to its slug for the canonical
    // path. (We can't use the raw XML because Astro wants us to
    // produce XML itself, and we want consistent formatting.)
    const matches = [...text.matchAll(/<loc>([^<]+)<\/loc>/g)];
    for (const m of matches) {
      const url = m[1].replace(SITE, "");
      // url is like /2026/05/06/some-slug or /noticia/<uuid>
      const m1 = url.match(/^\/(\d{4})\/(\d{2})\/(\d{2})\/([^/]+)\/?$/);
      if (m1) {
        items.push({
          id: "",
          slug: m1[4],
          slug_date: `${m1[1]}-${m1[2]}-${m1[3]}`,
          published_at: null,
        });
      }
    }
  }
} catch {
  items = [];
}

const now = new Date().toISOString();
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{items.map((a) => {
  const [y, m, d] = (a.slug_date || "").split("-");
  const url = y && m && d && a.slug
    ? `${SITE}/${y}/${m}/${d}/${a.slug}`
    : `${SITE}/`;
  return (
    <url>
      <loc>{url}</loc>
      <lastmod>{a.published_at || now}</lastmod>
      <changefreq>daily</changefreq>
      <priority>0.7</priority>
    </url>
  );
})}
</urlset>
