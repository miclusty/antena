---
import Layout from '../layouts/Layout.astro';
import App from '../App';
import SeoHead from '../components/SeoHead.astro';

const SITE = 'https://www.antena.com.ar';

// SSR: pre-fetch first 20 cards so HTML has content before JS hydrates.
// This also pre-fetches blindspot items — the blindspot title is typically
// the LCP element, so it must be in the initial HTML.
// If the fetch fails (e.g. build environment without a running API),
// the App falls back to client-side fetching with zero regression.
let initialFeed: unknown[] = []
let initialBlindspot: unknown[] = []
try {
  const API = (import.meta as Record<string, any>).env?.PUBLIC_API_BASE || 'https://akira-api.miclusty.workers.dev'
  const [feedRes, blindspotRes] = await Promise.all([
    fetch(`${API}/api/news/feed?limit=15&foryou=true`),
    fetch(`${API}/api/news/blindspot?limit=10`),
  ])
  if (feedRes.ok) {
    const data = await feedRes.json()
    initialFeed = data.news ?? []
  }
  if (blindspotRes.ok) {
    const data = await blindspotRes.json()
    initialBlindspot = data.items ?? []
  }
} catch {
  // API not reachable during build — client fetches on hydration
}
---

<Layout>
  <Fragment slot="head">
    <SeoHead
      title="Sintonizá tu realidad"
      description="Antena — Noticias sintetizadas de múltiples fuentes de cada localidad argentina. Mobile-first, sin tracking, 100% en español."
      canonical={SITE}
      ogType="website"
      ogImageAlt="Antena — Noticias hiperlocales de Argentina"
    />
  </Fragment>
  <App client:load initialFeed={initialFeed} initialBlindspot={initialBlindspot} />
</Layout>
