# =============================================================================
# Antena — Root environment template
# Copy to .env (gitignored) and fill in real values.
# Service-specific secrets go in packages/<pkg>/.dev.vars, not here.
# =============================================================================

# -----------------------------------------------------------------------------
# AKIRA — Python extraction engine
# All AKIRA_* settings are picked up by pydantic-settings in
# packages/akira/config.py via model_config = {"env_prefix": "AKIRA_"}
# -----------------------------------------------------------------------------
AKIRA_HOST=0.0.0.0
AKIRA_PORT=5000
AKIRA_DEBUG=false
AKIRA_DB_PATH=./packages/akira/data/akira.db
AKIRA_LOCATIONS_DB_PATH=./packages/akira/data/locations.db
# Rate limiter (seconds between requests to the same domain)
AKIRA_REQUEST_DELAY=1.5
# Circuit breaker (consecutive failures before pausing a source)
AKIRA_CIRCUIT_BREAKER_THRESHOLD=5
# Synthesis
AKIRA_SYNTHESIS_ENABLED=true
AKIRA_SYNTHESIS_MIN_CLUSTER_SIZE=3
AKIRA_SYNTHESIS_MAX_PER_HOUR=60
# Garbage collector
AKIRA_GC_INTERVAL_SEC=300

# -----------------------------------------------------------------------------
# MiniMax AI — used by AKIRA synthesis and Hermes skills
# -----------------------------------------------------------------------------
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# -----------------------------------------------------------------------------
# Cloudflare (production deployment)
# Provision services per docs/cloudflare-setup.md, then paste IDs here.
# The same IDs go into packages/api/wrangler.toml.
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Cloudflare D1 (news_cards, clusters, master_articles, sources, locations, categories)
CLOUDFLARE_D1_DATABASE_ID=your_d1_id
CLOUDFLARE_D1_DATABASE_NAME=antena

# Cloudflare KV (edge cache for hot reads; session storage for Astro)
CLOUDFLARE_KV_CACHE_ID=your_kv_id
CLOUDFLARE_KV_SESSION_ID=your_session_kv_id

# Cloudflare R2 (image storage)
CLOUDFLARE_R2_BUCKET=antena-images

# Cloudflare Vectorize (semantic search)
CLOUDFLARE_VECTORIZE_INDEX=news_embeddings
CLOUDFLARE_VECTORIZE_DIMENSIONS=384
CLOUDFLARE_VECTORIZE_METRIC=cosine

# Cloudflare Analytics Engine (read events, web vitals)
CLOUDFLARE_ANALYTICS_DATASET=feed_events

# Cloudflare Queues (image pipeline)
CLOUDFLARE_QUEUE_NAME=image-pipeline

# Cloudflare Workers AI (embeddings; available in every Worker)
# No setup needed; reference in code: env.AI.run("@cf/baai/bge-small-en-v1.5", { text: ["…"] })

# -----------------------------------------------------------------------------
# Ingest API keys (sent in Authorization: Bearer header)
# -----------------------------------------------------------------------------
PULSO_API_KEY=change-this-in-production
API_KEY=change-this-in-production

# -----------------------------------------------------------------------------
# Antena — public env vars (exposed to the browser)
# Set per environment: dev / staging / production
# These are PUBLIC values, safe to commit. Secrets must NOT be PUBLIC_*.
# -----------------------------------------------------------------------------
PUBLIC_API_BASE=http://localhost:8787
PUBLIC_AKIRA_BASE=http://localhost:5000
PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Optional: feature flags
# -----------------------------------------------------------------------------
ENABLE_VECTOR_SEARCH=true
ENABLE_ANALYTICS=true
ENABLE_PWA=true
ENABLE_CRON=true
