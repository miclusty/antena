{
  "name": "akira",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "pnpm --filter api dev & pnpm --filter antena dev",
    "build": "pnpm --filter antena build",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply akira-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply akira-db --remote",
    "validate": "pnpm typecheck && pnpm lint",
    "typecheck:api": "pnpm --filter api run typecheck",
    "typecheck:antena": "pnpm --filter antena run typecheck",
    "typecheck": "pnpm run typecheck:api && pnpm run typecheck:antena",
    "test": "pnpm --filter api run test && pnpm --filter antena run test",
    "test:e2e": "pnpm --filter antena run test:e2e",
    "lint": "pnpm --filter api run lint && pnpm --filter antena run lint",
    "lighthouse": "lhci autorun",
    "sync:d1": "cd packages/akira && source .venv/bin/activate && python scripts/sync_to_d1_remote.py",
    "sync:domain": "python scripts/setup-custom-domain.py",
    "deploy:staging": "wrangler pages deploy ./packages/antena/dist --project-name=antena --branch=develop",
    "deploy:prod": "wrangler pages deploy ./packages/antena/dist --project-name=antena --branch=main"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
